# Backend Configuration
DEBUG=false
CLUSTER_MONITOR_HOME=/app
CVS_LIB_PATH=/opt/cvs/lib

# Polling Configuration
POLLING__INTERVAL=60
POLLING__FAILURE_THRESHOLD=5

# SSH Passwords — set these so the Go daemons initialise correctly after every
# rebuild without requiring a manual "Save & Apply" in the UI.
# Copy this file to .env and fill in the actual passwords.
# NEVER commit .env to git (it is already in .gitignore).
GPU_NODE_SSH_PASSWORD=
SWITCH_SSH_PASSWORD=

# Redis
REDIS_PASSWORD=cvs_cluster_mon

# Frontend Configuration (for development)
VITE_API_URL=http://localhost:8001/api
VITE_WS_URL=ws://localhost:8001/ws/metrics
