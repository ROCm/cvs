# rack.yaml — Rack-level IFoE monitoring configuration
# Copy this file to config/rack.yaml and edit as needed.
# Passwords are NEVER stored here; provide them via the Rack Config UI.

# Compute tray IPs or hostnames (max 18)
compute_trays:
  - 192.168.1.101
  - 192.168.1.102
  # - 192.168.1.103  # add up to 18

# Switch tray IPs or hostnames (max 6)
switch_trays:
  - 192.168.2.1
  - 192.168.2.2

# SSH settings for compute trays
compute_ssh:
  username: admin
  auth_method: key      # "key" or "password"
  key_file: ~/.ssh/id_rsa
  timeout: 30

# SSH settings for switch trays (SONiC OS)
switch_ssh:
  username: admin
  auth_method: key
  key_file: ~/.ssh/id_rsa
  timeout: 30

# Collection interval in seconds (default 120)
poll_interval: 120
