cluster:
  nodes_file: config/nodes.txt

  ssh:
    username: your_username
    key_file: ~/.ssh/id_rsa
    timeout: 30

    jump_host:
      enabled: false
      host: jumphost.example.com
      username: your_username
      key_file: ~/.ssh/id_rsa
      node_username: your_username
      node_key_file: ~/.ssh/id_rsa

  polling:
    interval: 60
    batch_size: 10
    stagger_delay: 2
    failure_threshold: 5

  alerts:
    gpu_temp_threshold: 85.0
    gpu_util_threshold: 95.0

  storage:
    redis:
      url: redis://localhost:6379
      db: 0
      password: null          # set to a string to enable Redis AUTH
      snapshot_max_entries: 1000
      event_max_entries: 10000

  rccl:
    ras_port: 28028
    poll_interval: 30
    collective_timeout_secs: 10
    debug_log_path: null
