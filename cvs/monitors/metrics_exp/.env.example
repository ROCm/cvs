# GPU Fleet & Control Plane Monitor — Environment Configuration
# Copy this file to .env and fill in your values before running docker compose.
# Lines starting with # are comments. All passwords below MUST be changed.
#
# SECURITY: Never commit .env to version control. It is listed in .gitignore.

# ============================================
# PostgreSQL — Configuration database
# ============================================
POSTGRES_DB=fleet_monitor
POSTGRES_USER=fleet
# REQUIRED: Change this password before deploying
POSTGRES_PASSWORD=change_this_password

# ============================================
# Prometheus — Metrics storage
# ============================================
# How long to keep metrics data
PROMETHEUS_RETENTION_TIME=15d
# Maximum disk space for metrics (whichever limit is hit first applies)
PROMETHEUS_RETENTION_SIZE=50GB

# ============================================
# Grafana — Dashboards & visualization
# ============================================
GRAFANA_ADMIN_USER=admin
# REQUIRED: Change this password before deploying
GRAFANA_ADMIN_PASSWORD=change_this_password
# Public URL users access Grafana on. Used by nginx overlay (docker-compose.nginx.yml).
# Options:
#   Private/VPN-only deployment (no TLS proxy needed):
#     GRAFANA_ROOT_URL=http://localhost:30030
#   Public IP, Let's Encrypt via nip.io (test/staging — no DNS setup needed):
#     GRAFANA_ROOT_URL=https://<ip>-<ip>-<ip>-<ip>.nip.io
#   Public IP, AMD-issued cert (production — requires DNS + cert from dl.casbsecurity@amd.com):
#     GRAFANA_ROOT_URL=https://chi-metrics-exp-mon.amd.com
GRAFANA_ROOT_URL=http://localhost:30030
# Optional: pre-provision a Grafana API key (leave blank to use admin credentials)
GRAFANA_API_KEY=

# ============================================
# Fleet Manager — Web UI & API
# ============================================
# REQUIRED: Generate a strong random secret key, e.g.:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-change-in-production

# ============================================
# Loki — Log aggregation
# ============================================
# Default retention is set in server/config/loki/loki-config.yml (7 days).
# To override, edit loki-config.yml directly.

# ============================================
# Optional overrides
# ============================================
# Set to "true" to drop and recreate all database tables on startup.
# WARNING: destroys all configuration data. Use only for fresh installs.
RESET_DATABASE=false
