      "targets": [{"expr": "topk(10, sum by (hostname) (rate(rdma_stat_tx_cnp_pkts{node_group=~\"$nodegroup\"}[5m]) + rate(rdma_stat_rx_cnp_pkts{node_group=~\"$nodegroup\"}[5m])))", "legendFormat": "{{hostname}}", "instant": true}],
      "options": {"orientation": "horizontal", "showValue": "always"},
      "fieldConfig": {"defaults": {"unit": "pps", "color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 10}, {"color": "red", "value": 100}]}}}
    },
    {
      "id": 92,
      "type": "barchart",
      "title": "Top 10 Nodes by Pacing Events",
