# =============================================
# Environment & secrets — NEVER COMMIT THESE
# =============================================
.env
*.env.local
*.env.production

# SSH keys uploaded via the UI
ssh_keys/

# Uploaded kubeconfig files
# (stored alongside SSH keys — Fleet Manager writes these at runtime)
*_kubeconfig

# TLS / certificate files
*.pem
*.key
*.crt
*.cer
*.pfx
id_rsa*
id_ed25519*

# =============================================
# Runtime data — auto-generated, not source
# =============================================

# Prometheus target files (contain real node IPs — generated at runtime)
server/config/prometheus/targets/*.json
!server/config/prometheus/targets/.gitkeep

# Docker named volumes (data directories when using local bind mounts)
prometheus_data/
loki_data/
grafana_data/
postgres_data/

# =============================================
# Python
# =============================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
env/
.venv/
*.egg-info/
build/
dist/
*.egg
.coverage
htmlcov/
.pytest_cache/

# =============================================
# Node.js / Frontend
# =============================================
node_modules/
.npm
*.log

# Built frontend bundle (regenerated by docker compose build)
server/fleet_manager/static/assets/
server/fleet_manager/static/index.html

# =============================================
# IDE & OS
# =============================================
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Claude Code AI assistant working files
.claude/

# =============================================
# Docker
# =============================================
.docker/

# =============================================
# Database
# =============================================
*.db
*.sqlite
*.sqlite3

# =============================================
# Temporary files
# =============================================
*.tmp
*.temp
tmp/
temp/

# =============================================
# Deployment-specific scripts (local overrides)
# =============================================
nuke-and-rebuild.sh
deploy-local.sh
