{
  "rccl": {
    "run": {
      "env_script": "/root/env_source_file.sh",
      "num_ranks": 16,
      "ranks_per_node": 8,
      "collectives": [
        "all_reduce_perf",
        "all_gather_perf",
        "broadcast_perf"
      ],
      "datatype": "float",
      "start_size": "1024",
      "end_size": "16g",
      "step_factor": "2",
      "warmups": "10",
      "iterations": "20",
      "cycles": "1"
    },
    "validation": {
      "profile": "strict",
      "thresholds": {
        "all_reduce_perf": {
          "bus_bw": {
            "8589934592": 330.0,
            "17179869184": 350.0
          }
        },
        "all_gather_perf": {
          "bus_bw": {
            "8589934592": 330.0,
            "17179869184": 350.0
          }
        },
        "broadcast_perf": {
          "bus_bw": {
            "8589934592": 310.0,
            "17179869184": 312.0
          }
        }
      }
    },
    "artifacts": {
      "output_dir": "/tmp/rccl_cvs_out",
      "export_raw": false
