{
    "_comment": "ISL+OSL must fit 8192 context (7168+1024=8192). CVS expects percentile_metrics (not percentiles_metrics). For vLLM 0.21+ nightlies, InferenceX upstream gptoss_fp4_mi300x.sh calls vllm serve without --enforce-eager, so CUDA graph capture still runs and VLLM_ENFORCE_EAGER alone does not help; this suite defaults use_host_mounted_server_script to the CVS wrapper (CLI --enforce-eager). benchmark_server_script_path \"auto\" uses checkout cvs/input/.../benchmark_server_scripts when present, else stages the bundled wrapper under {log_dir}/inference-max/host_scripts_bundled/. Override with an absolute path if needed. volume_dict maps LOGS/.../workspace to /workspace for server.log on the host. env_dict mirrors key ROCm exports from the InferenceX script.",
    "config": {
        "container_image": "rocm/utd-private:vllm-0.21.0-ubuntu24.04-py3.13-nightlies-device-all-cdna-rocm7.14.0a20260602-ad7125a43",
        "container_name": "inference_max_rocm",
        "use_host_mounted_server_script": true,
        "benchmark_server_script_path": "auto",
        "vllm_enforce_eager": true,
        "nnodes": "1",
        "inferencemax_repo": "https://github.com/SemiAnalysisAI/InferenceX.git",
        "benchmark_script_repo": "https://github.com/kimbochen/bench_serving.git",
        "hf_token_file": "/home/{user-id}/.hf_token",
        "shm_size": "128G",
        "log_dir": "/home/{user-id}/LOGS",
        "container_config": {
            "device_list": [
                "/dev/dri",
                "/dev/kfd"
            ],
            "volume_dict": {
                "/home/{user-id}": "/home/{user-id}",
                "/home/{user-id}/LOGS/inference-max/workspace": "/workspace"
            },
            "env_dict": {
                "AMDGCN_USE_BUFFER_OPS": "0",
                "VLLM_ROCM_USE_AITER": "1",
                "VLLM_ROCM_QUICK_REDUCE_QUANTIZATION": "INT4",
                "VLLM_GPU_MEMORY_UTIL": "0.95"
            }
        }
    },
    "benchmark_params": {
        "gpt-oss-120b": {
            "backend": "vllm",
            "base_url": "http://0.0.0.0",
            "port_no": "8000",
            "dataset_name": "random",
            "max_concurrency": "64",
            "model": "openai/gpt-oss-120b",
            "num_prompts": "1000",
            "input_sequence_length": "7168",
            "output_sequence_length": "1024",
            "burstiness": "1.0",
            "seed": "0",
            "max_model_length": "8192",
            "random_range_ratio": "0.8",
            "random_prefix_len": "0",
            "tensor_parallelism": "8",
            "tokenizer_mode": "auto",
            "percentile_metrics": "ttft,tpot,itl,e2el",
            "metric_percentiles": "99",
            "server_script": "fixed_seq_len/gptoss_fp4_mi300x.sh",
            "bench_serv_script": "benchmark_serving.py"
        }
    }
}
