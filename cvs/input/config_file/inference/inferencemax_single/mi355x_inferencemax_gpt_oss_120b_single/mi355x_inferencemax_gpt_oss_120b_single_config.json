{
    "_comment": "Single-node InferenceMax sample. Set container_image and container_name (e.g. replace <changeme>). ISL+OSL within max_model_length; CVS uses percentile_metrics.",
    "config": {
        "container_image": "<changeme>",
        "container_name": "<changeme>",
        "hf_token_file": "/home/{user-id}/.hf_token",
        "shm_size": "128G",
        "log_dir": "/home/{user-id}/LOGS",
        "container_config": {
            "device_list": [
                "/dev/dri",
                "/dev/kfd"
            ],
            "volume_dict": {
                "/home/{user-id}": "/home/{user-id}"
            },
            "env_dict": {}
        }
    },
    "benchmark_params": {
        "gpt-oss-120b": {
            "backend": "vllm",
            "base_url": "http://0.0.0.0",
            "port_no": "8000",
            "dataset_name": "random",
            "max_concurrency": "64",
            "model": "openai/gpt-oss-120b",
            "num_prompts": "1000",
            "input_sequence_length": "7168",
            "output_sequence_length": "1024",
            "burstiness": "1.0",
            "seed": "0",
            "max_model_length": "8192",
            "random_range_ratio": "0.8",
            "random_prefix_len": "0",
            "tensor_parallelism": "8",
            "tokenizer_mode": "auto",
            "percentile_metrics": "ttft,tpot,itl,e2el",
            "metric_percentiles": "99",
            "client_poll_count": "50",
            "client_poll_wait_time": "60",
            "server_script": "fixed_seq_len/vllm_serve_mi300x.sh",
            "bench_serv_script": "benchmark_serving.py"
        }
    }
}
