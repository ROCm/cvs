    "remote": 0
  },
  "container": {
    "lifetime": "per_run",
    "name": "pytorch_vision_therock",
    "image": "registry-sc-harbor.amd.com/framework/therock-main:1332_gfx94X_7.13.0a20260430_ubuntu24.04_py3.12_pytorch_release-2.11_443606e",
    "runtime": {
      "name": "docker",
      "args": {
        "network": "host",
        "ipc": "host",
