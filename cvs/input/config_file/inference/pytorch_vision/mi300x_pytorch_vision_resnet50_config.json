{
  "schema_version": 1,
  "framework": "pytorch_vision",
  "gpu_arch": "mi300x",
  "enforce_thresholds": false,
  "threshold_json": "/home/daforbes/gitlab/cvs/cvs/input/config_file/inference/pytorch_vision/mi300x_pytorch_vision_resnet50_threshold.json",
  "paths": {
